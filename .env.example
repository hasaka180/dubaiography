# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.
# With NONE of these set, the site still runs: content falls back to data/articles.json
# and the studio is open locally (but disabled in production).

# Password that gates /studio and the write/upload APIs.
# If unset locally the gate is skipped. In production it is REQUIRED (studio is disabled without it).
STUDIO_PASSWORD=

# ── Appwrite (article storage) ──
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1   # use your project's regional endpoint, e.g. https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_COLLECTION_ID=

# ── Cloudflare R2 (media uploads, organised into articles/ covers/ misc/ folders) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# The bucket's public URL, e.g. https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_BASE_URL=

# ── SEO ──
# Your production URL (used for sitemap, robots, canonical/OG).
NEXT_PUBLIC_SITE_URL=https://dubaiography.com
# Google Search Console HTML-tag verification token (the content="..." value).
GOOGLE_SITE_VERIFICATION=
